# ============================================================
# VVS IMS — Sovereign Environment Configuration Template
# ============================================================
# INSTRUCTIONS: Copy this file to .env and fill in your rotated credentials.
# NEVER commit .env to source control. The .gitignore blocks it.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vvs_ims_pristine
DB_USER=sovereign_admin
DB_PASSWORD=ROTATED_SECURE_PASSWORD_HERE

# JWT Authentication
JWT_SIGNING_KEY=ROTATED_SUPER_SECRET_HMAC_SHA256_KEY_MINIMUM_64_CHARS_HERE
JWT_ISSUER=VvsIms
JWT_AUDIENCE=VvsIms
JWT_ACCESS_TOKEN_MINUTES=480
JWT_REFRESH_TOKEN_DAYS=7

# Amazon SP-API
AMAZON_LWA_CLIENT_ID=ROTATED_AMAZON_CLIENT_ID_HERE
AMAZON_LWA_CLIENT_SECRET=ROTATED_AMAZON_SECRET_HERE
AMAZON_SELLER_ID=ROTATED_SELLER_ID_HERE
AMAZON_MARKETPLACE_ID=ROTATED_MARKETPLACE_ID_HERE
AMAZON_REGION=na

# Shopify
SHOPIFY_DOMAIN=ROTATED_SHOPIFY_DOMAIN_HERE
SHOPIFY_ADMIN_API_TOKEN=shpat_ROTATED_SHOPIFY_TOKEN_HERE

# BestBuy Marketplace
BESTBUY_AUTH_TOKEN=ROTATED_BESTBUY_TOKEN_HERE
BESTBUY_SHOP_ID=ROTATED_SHOP_ID_HERE

# CORS
CORS_ALLOWED_ORIGINS=https://vvs-ims.sovereign.local,https://localhost:4200

# Application
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
